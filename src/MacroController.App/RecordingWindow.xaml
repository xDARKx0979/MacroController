<Window x:Class="MacroController.App.RecordingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Recording Macro" Height="480" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Recording" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="StatusText" Foreground="Gray" Margin="0,0,0,10"/>

        <Border Grid.Row="2" BorderBrush="#FF3F3F3F" BorderThickness="1" CornerRadius="4">
            <ScrollViewer x:Name="StepsScroll" VerticalScrollBarVisibility="Auto" Padding="6">
                <StackPanel x:Name="StepsPanel"/>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="3" x:Name="DoneButton" Content="Done" Click="DoneButton_Click"
                HorizontalAlignment="Right" Width="90" Padding="10,4" Margin="0,12,0,0" IsEnabled="False"/>
    </Grid>
</Window>

<Window x:Class="MacroController.App.VendorImportResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Razer Import" Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        Icon="Assets/icon.ico">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Razer Import" FontSize="22" FontWeight="Bold" Margin="0,0,0,14"/>

        <TextBlock x:Name="EmptyText" Grid.Row="1"
                   Text="No Razer macro files were found in their usual locations on this PC."
                   Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap"
                   VerticalAlignment="Top" Visibility="Collapsed"/>

        <ListBox x:Name="ResultsList" Grid.Row="1" Margin="0,0,0,14"
                 Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,0,0,8"/>
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="14,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding Reason}" Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,4,0,0"
                                       TextWrapping="Wrap" Visibility="{Binding ReasonVisibility}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close" Click="CloseButton_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="MacroController.App.AddMacroStepWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Step" Height="300" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Type:" Width="110" VerticalAlignment="Center"/>
            <ComboBox x:Name="StepTypeCombo" Width="200" SelectionChanged="StepTypeCombo_SelectionChanged">
                <ComboBoxItem Content="Key Press"/>
                <ComboBoxItem Content="Mouse Click"/>
                <ComboBoxItem Content="Mouse Wheel"/>
                <ComboBoxItem Content="Mouse Double-Click"/>
            </ComboBox>
        </StackPanel>

        <StackPanel x:Name="CapturePanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Key / Button:" Width="110" VerticalAlignment="Center"/>
            <TextBlock x:Name="CapturedText" Text="(none)" Width="140" VerticalAlignment="Center"/>
            <Button x:Name="CaptureButton" Content="Capture..." Click="CaptureButton_Click" Padding="8,2"/>
        </StackPanel>

        <StackPanel x:Name="WheelDirectionPanel" Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock Text="Direction:" Width="110" VerticalAlignment="Center"/>
            <ComboBox x:Name="WheelDirectionCombo" Width="120" SelectedIndex="0" SelectionChanged="WheelDirectionCombo_SelectionChanged">
                <ComboBoxItem Content="Vertical"/>
                <ComboBoxItem Content="Horizontal"/>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Delay before (ms):" Width="110" VerticalAlignment="Center"/>
            <TextBox x:Name="DelayBeforeInput" Width="100" Text="50"/>
        </StackPanel>

        <StackPanel x:Name="HoldPanel" Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="HoldLabel" Text="Hold (ms):" Width="110" VerticalAlignment="Center"/>
            <TextBox x:Name="HoldInput" Width="100" Text="50"/>
        </StackPanel>

        <StackPanel x:Name="WheelDeltaPanel" Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock Text="Delta:" Width="110" VerticalAlignment="Center"/>
            <TextBox x:Name="WheelDeltaInput" Width="100" Text="120"/>
            <TextBlock x:Name="WheelHintText" Text="(+ = up, - = down)" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
        </StackPanel>

        <StackPanel x:Name="ClickGapPanel" Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock Text="Gap between clicks (ms):" Width="160" VerticalAlignment="Center"/>
            <TextBox x:Name="ClickGapInput" Width="100" Text="50"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add" IsDefault="True" Click="AddButton_Click" Width="70" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Width="70"/>
        </StackPanel>
    </Grid>
</Window>

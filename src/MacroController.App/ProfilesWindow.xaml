<Window x:Class="MacroController.App.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Profiles" Height="440" Width="460"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Profiles" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox x:Name="ProfileList" Grid.Row="1" Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="2,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Subtitle}" Foreground="Gray" FontSize="11"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Edit Profile" Tag="{Binding}" Click="EditButton_Click" Padding="10,4" Margin="6,0"/>
                        <Button Grid.Column="2" Content="Delete" Tag="{Binding}" Click="DeleteButton_Click" Padding="10,4"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Make New Profile..." Click="NewProfileButton_Click" Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Save &amp; Close" Click="SaveButton_Click" Padding="10,4" Margin="0,0,8,0"/>
            <Button Content="Cancel" IsCancel="True" Padding="10,4"/>
        </StackPanel>
    </Grid>
</Window>

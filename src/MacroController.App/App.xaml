<Application x:Class="MacroController.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MacroController.App"
             StartupUri="MainWindow.xaml"
             ThemeMode="Dark">
    <Application.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#7C5CFC"/>
        <SolidColorBrush x:Key="CardBrush" Color="#23262F"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#9AA0AC"/>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ListRowButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
        </Style>
    </Application.Resources>
</Application>

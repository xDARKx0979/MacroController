<Window x:Class="MacroController.App.MacroEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit Macro" Height="640" Width="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- name -->
            <RowDefinition Height="Auto"/> <!-- toolbar -->
            <RowDefinition Height="Auto"/> <!-- shortcut -->
            <RowDefinition Height="Auto"/> <!-- playback mode -->
            <RowDefinition Height="Auto"/> <!-- standard delay -->
            <RowDefinition Height="Auto"/> <!-- status -->
            <RowDefinition Height="*"/>    <!-- step list -->
            <RowDefinition Height="Auto"/> <!-- add action -->
            <RowDefinition Height="Auto"/> <!-- save/close -->
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" x:Name="NameInput" FontSize="22" FontWeight="Bold" BorderThickness="0"
                 Background="Transparent" Padding="0" Margin="0,0,0,12" TextChanged="NameInput_TextChanged"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Open..." Click="OpenButton_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button x:Name="RecordButton" Content="Record" Click="RecordButton_Click" Padding="8,4" Margin="0,0,8,0"/>
            <Button x:Name="PlayButton" Content="Play" Click="PlayButton_Click" Padding="8,4"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
            <TextBlock Text="Global shortcut:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>
            <TextBlock x:Name="ShortcutText" Text="None" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <Button x:Name="CaptureShortcutButton" Content="Capture..." Click="CaptureShortcutButton_Click" Padding="8,4" Margin="0,0,6,0"/>
            <Button Content="Clear" Click="ClearShortcutButton_Click" Padding="8,4"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="When triggered:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>

            <ComboBox Grid.Column="1" x:Name="PlayModeCombo" Width="220" SelectionChanged="PlayModeCombo_SelectionChanged">
                <ComboBoxItem Content="Play once"/>
                <ComboBoxItem Content="Play while held"/>
                <ComboBoxItem Content="Toggle on/off"/>
                <ComboBoxItem Content="Repeat a number of times"/>
            </ComboBox>

            <StackPanel Grid.Column="2" x:Name="RepeatCountPanel" Orientation="Horizontal" Margin="10,0,0,0"
                        Visibility="Collapsed" VerticalAlignment="Center">
                <TextBox x:Name="RepeatCountInput" Width="50" LostFocus="RepeatCountInput_LostFocus"/>
                <TextBlock Text="times" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Delay between steps:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>

            <ComboBox x:Name="DelayModeCombo" Width="160" SelectionChanged="DelayModeCombo_SelectionChanged">
                <ComboBoxItem Content="Use recorded delays"/>
                <ComboBoxItem Content="Fixed delay"/>
                <ComboBoxItem Content="Random delay range"/>
                <ComboBoxItem Content="No delay"/>
            </ComboBox>

            <StackPanel x:Name="FixedDelayPanel" Orientation="Horizontal" Margin="10,0,0,0"
                        Visibility="Collapsed" VerticalAlignment="Center">
                <TextBox x:Name="FixedDelayInput" Width="50" LostFocus="FixedDelayInput_LostFocus"/>
                <TextBlock Text="ms" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <StackPanel x:Name="RandomDelayPanel" Orientation="Horizontal" Margin="10,0,0,0"
                        Visibility="Collapsed" VerticalAlignment="Center">
                <TextBox x:Name="RandomDelayMinInput" Width="50" LostFocus="RandomDelayMinInput_LostFocus"/>
                <TextBlock Text="to" Margin="4,0,4,0" VerticalAlignment="Center" Foreground="Gray"/>
                <TextBox x:Name="RandomDelayMaxInput" Width="50" LostFocus="RandomDelayMaxInput_LostFocus"/>
                <TextBlock Text="ms" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="6" BorderBrush="#FF3F3F3F" BorderThickness="1" CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="6">
                <StackPanel x:Name="StepsPanel"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="+ Add Step..." Click="AddStepButton_Click" Padding="8,6"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Click="SaveButton_Click" Width="70" Margin="0,0,8,0"/>
            <Button Content="Save As..." Click="SaveAsButton_Click" Width="80" Margin="0,0,8,0"/>
            <Button Content="Close" IsCancel="True" Width="70"/>
        </StackPanel>
    </Grid>
</Window>
